# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard/project/<project-id>/settings/api
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Never expose this in the client — only used in Supabase Edge Functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Plaid
# Get these from: https://dashboard.plaid.com/developers/keys
# ─────────────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret          # sandbox / development / production secret
PLAID_ENV=sandbox                        # sandbox | development | production

# The public URL of your plaid-webhook edge function (set after first deploy)
PLAID_WEBHOOK_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co/functions/v1/plaid-webhook

# ─────────────────────────────────────────────────────────────────────────────
# Expo Push Notifications
# Get from: https://expo.dev/accounts/<username>/settings/access-tokens
# ─────────────────────────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot (free alternative to SMS for critical alerts)
# Create a bot via @BotFather on Telegram to get a token
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff...
